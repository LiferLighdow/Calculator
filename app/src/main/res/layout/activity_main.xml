<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenDrawer"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            app:iconSize="28dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- tvResult: Smaller, faint, on TOP -->
        <EditText
            android:id="@+id/tvResult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@null"
            android:cursorVisible="false"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="end"
            android:inputType="none"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:text="0"
            android:alpha="0.6"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="32sp"
            android:includeFontPadding="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnOpenDrawer" />

        <!-- tvExpression: Large, BLACK, on BOTTOM (The main focus) -->
        <EditText
            android:id="@+id/tvExpression"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@null"
            android:cursorVisible="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="end"
            android:hint="0"
            android:inputType="none"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:textColor="?attr/colorOnSurface"
            android:textSize="56sp"
            android:textStyle="bold"
            android:includeFontPadding="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvResult"
            tools:text="sin(90°) = 1" />

        <androidx.constraintlayout.helper.widget.Flow
            android:id="@+id/mainFlow"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="32dp"
            app:constraint_referenced_ids="btnAC,btnDel,btnOpenParen,btnCloseParen,btn7,btn8,btn9,btnDiv,btn4,btn5,btn6,btnMul,btn1,btn2,btn3,btnSub,btn0,btnDot,btnEqual,btnAdd"
            app:flow_horizontalGap="12dp"
            app:flow_maxElementsWrap="4"
            app:flow_verticalGap="12dp"
            app:flow_wrapMode="aligned"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvExpression" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btnAC" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="AC" android:textColor="?attr/colorError" android:textSize="20sp" android:textStyle="bold" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnDel" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="⌫" android:textColor="?attr/colorPrimary" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnOpenParen" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="(" android:textColor="?attr/colorPrimary" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnCloseParen" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text=")" android:textColor="?attr/colorPrimary" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn7" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="7" android:textSize="24sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn8" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="8" android:textSize="24sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn9" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="9" android:textSize="24sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnDiv" style="@style/Widget.Material3.Button" android:layout_width="0dp" android:layout_height="0dp" android:text="÷" android:textSize="28sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn4" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="4" android:textSize="24sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn5" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="5" android:textSize="24sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn6" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="6" android:textSize="24sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnMul" style="@style/Widget.Material3.Button" android:layout_width="0dp" android:layout_height="0dp" android:text="×" android:textSize="28sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn1" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="1" android:textSize="24sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn2" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="2" android:textSize="24sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn3" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="3" android:textSize="24sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnSub" style="@style/Widget.Material3.Button" android:layout_width="0dp" android:layout_height="0dp" android:text="-" android:textSize="28sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn0" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="0" android:textSize="24sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnDot" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="0dp" android:text="." android:textSize="24sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnEqual" style="@style/Widget.Material3.Button" android:layout_width="0dp" android:layout_height="0dp" android:text="=" android:backgroundTint="?attr/colorPrimary" android:textColor="?attr/colorOnPrimary" android:textSize="28sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnAdd" style="@style/Widget.Material3.Button" android:layout_width="0dp" android:layout_height="0dp" android:text="+" android:textSize="28sp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="?attr/colorSurface">
        <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="match_parent">
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">

                 <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoToConverter"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/open_converter"
                    app:icon="@android:drawable/ic_menu_compass"
                    app:layout_constraintTop_toTopOf="parent" />

                 <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoToSpecialCalculators"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/open_special"
                    app:icon="@android:drawable/ic_menu_add"
                    app:layout_constraintTop_toBottomOf="@id/btnGoToConverter" />

                 <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoToGeometry"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/open_geometry"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:layout_constraintTop_toBottomOf="@id/btnGoToSpecialCalculators" />

                 <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoToMathNotepad"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/open_math_notepad"
                    app:icon="@android:drawable/ic_menu_agenda"
                    app:layout_constraintTop_toBottomOf="@id/btnGoToGeometry" />

                 <TextView android:id="@+id/tvSciTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="@string/advanced_math" android:textAppearance="@style/TextAppearance.Material3.TitleLarge" app:layout_constraintTop_toBottomOf="@id/btnGoToMathNotepad" />

                 <TextView android:id="@+id/tvGroup1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/group_trig" android:textAppearance="@style/TextAppearance.Material3.LabelLarge" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvSciTitle" />

                 <androidx.constraintlayout.helper.widget.Flow
                    android:id="@+id/sciFlow1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:constraint_referenced_ids="btnSin,btnCos,btnTan,btnSec,btnCsc,btnCot,btnAsin,btnAcos,btnAtan,btnSinh,btnCosh,btnTanh,btnAsinh,btnAcosh,btnAtanh,btnLog,btnLn,btnLog2,btnSqrt,btnCbrt,btnPow,btnFact,btnAbs,btnCeil,btnFloor,btnPercent,btnDegree"
                    app:flow_horizontalGap="8dp"
                    app:flow_maxElementsWrap="3"
                    app:flow_verticalGap="8dp"
                    app:flow_wrapMode="aligned"
                    app:layout_constraintTop_toBottomOf="@id/tvGroup1" />

                 <com.google.android.material.button.MaterialButton android:id="@+id/btnSin" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="sin" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnCos" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="cos" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnTan" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="tan" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnSec" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="sec" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnCsc" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="csc" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnCot" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="cot" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnAsin" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="asin" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnAcos" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="acos" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnAtan" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="atan" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnSinh" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="sinh" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnCosh" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="cosh" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnTanh" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="tanh" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnAsinh" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="asinh" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnAcosh" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="acosh" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnAtanh" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="atanh" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnLog" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="log" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnLn" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="ln" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnLog2" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="log2" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnSqrt" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="√" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnCbrt" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="∛" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnPow" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="^" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnFact" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="n!" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnAbs" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="abs" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnCeil" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="ceil" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnFloor" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="floor" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnPercent" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="%" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnDegree" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="°" />

                 <TextView android:id="@+id/tvGroup2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="@string/group_const" android:textAppearance="@style/TextAppearance.Material3.LabelLarge" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/sciFlow1" />
                 <androidx.constraintlayout.helper.widget.Flow android:id="@+id/sciFlow2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" app:constraint_referenced_ids="btnPi,btnE,btnPhi,btnGamma,btnImaginary,btnGCD,btnLCM,btnNcr,btnNpr" app:flow_horizontalGap="8dp" app:flow_maxElementsWrap="3" app:flow_verticalGap="8dp" app:flow_wrapMode="aligned" app:layout_constraintTop_toBottomOf="@id/tvGroup2" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnPi" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="π" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnE" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="e" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnPhi" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="φ" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnGamma" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="γ" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnImaginary" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="i" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnGCD" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="gcd" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnLCM" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="lcm" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnNcr" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="nCr" />
                 <com.google.android.material.button.MaterialButton android:id="@+id/btnNpr" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:text="nPr" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>